# Base URL of the Staccato FastAPI backend (no trailing slash).
BACKEND_URL=http://localhost:8000

# Bearer token attached server-side to every /admin call.
# Never exposed to the browser — all backend traffic goes through
# Next.js server code (route handlers / server components).
ADMIN_API_TOKEN=change-me

# --- Clerk org gating (optional in dev) ---
# Leave BOTH unset to run open in dev mode (a warning banner is shown).
# Set both in production; see README.md "Enabling Clerk" for the code drop-in.
#NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
#CLERK_SECRET_KEY=sk_live_...
