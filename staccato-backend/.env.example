# Copy to .env for local dev. Everything has a dev-safe default; these are the
# production knobs.

STACCATO_ENV=dev                          # dev | test | prod
STACCATO_DATABASE_URL=sqlite+aiosqlite:///./staccato_dev.sqlite3
# Production (Neon): postgresql+asyncpg://user:pass@host/db
# Procrastinate DSN (plain psycopg URL); defaults to STACCATO_DATABASE_URL
STACCATO_PROCRASTINATE_DATABASE_URL=

STACCATO_AUTH_MODE=dev                    # clerk | dev ("Bearer dev:<user-id>")
STACCATO_CLERK_JWKS_URL=                  # https://<tenant>.clerk.accounts.dev/.well-known/jwks.json
STACCATO_CLERK_ISSUER=
STACCATO_ADMIN_API_TOKEN=dev-admin-token  # rotate in prod; used by staccato-admin's server proxy

STACCATO_STORAGE_BACKEND=local            # r2 | local
STACCATO_MEDIA_ROOT=./media
STACCATO_PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media
STACCATO_R2_ENDPOINT_URL=                 # https://<account>.r2.cloudflarestorage.com
STACCATO_R2_BUCKET=staccato-artifacts
STACCATO_R2_ACCESS_KEY_ID=
STACCATO_R2_SECRET_ACCESS_KEY=

STACCATO_FREE_ANALYSES_LIMIT=3
STACCATO_SHARE_BASE_URL=http://localhost:3000

STACCATO_CHANNEL_SCAN_DEFAULT_N=20
STACCATO_BATCH_QUEUE_THROTTLE_S=0
STACCATO_YOUTUBE_API_KEY=                 # optional; yt-dlp fallback without it

STACCATO_APPLE_VERIFY_SIGNATURES=true
# Directory of pinned Apple root CA certs (PEM/DER) for notification chain
# validation. Download from https://www.apple.com/certificateauthority/
# (Apple Root CA - G2 and G3). Verification fails closed without them.
STACCATO_APPLE_ROOT_CA_DIR=./apple-roots
STACCATO_APPLE_BUNDLE_ID=com.anythingsimple.staccato

# Comma-separated CORS allowlist for browsers. "*" (dev default) allows any
# origin; production should list the frontend/share origins explicitly.
STACCATO_CORS_ALLOW_ORIGINS=*

# Upper bound for live-capture session duration (seconds).
STACCATO_LIVE_SESSION_MAX_DURATION_S=21600
