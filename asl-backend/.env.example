# Copy to .env for local dev. Everything has a dev-safe default; these are the
# production knobs.

ASL_ENV=dev                          # dev | test | prod
ASL_DATABASE_URL=sqlite+aiosqlite:///./asl_dev.sqlite3
# Production (Neon): postgresql+asyncpg://user:pass@host/db
# Procrastinate DSN (plain psycopg URL); defaults to ASL_DATABASE_URL
ASL_PROCRASTINATE_DATABASE_URL=

ASL_AUTH_MODE=dev                    # clerk | dev ("Bearer dev:<user-id>")
ASL_CLERK_JWKS_URL=                  # https://<tenant>.clerk.accounts.dev/.well-known/jwks.json
ASL_CLERK_ISSUER=
ASL_ADMIN_API_TOKEN=dev-admin-token  # rotate in prod; used by asl-admin's server proxy

ASL_STORAGE_BACKEND=local            # r2 | local
ASL_MEDIA_ROOT=./media
ASL_PUBLIC_MEDIA_BASE_URL=http://localhost:8000/media
ASL_R2_ENDPOINT_URL=                 # https://<account>.r2.cloudflarestorage.com
ASL_R2_BUCKET=asl-artifacts
ASL_R2_ACCESS_KEY_ID=
ASL_R2_SECRET_ACCESS_KEY=

ASL_FREE_ANALYSES_LIMIT=3
ASL_SHARE_BASE_URL=http://localhost:3000

ASL_CHANNEL_SCAN_DEFAULT_N=20
ASL_BATCH_QUEUE_THROTTLE_S=0
ASL_YOUTUBE_API_KEY=                 # optional; yt-dlp fallback without it

ASL_APPLE_VERIFY_SIGNATURES=true
# Directory of pinned Apple root CA certs (PEM/DER) for notification chain
# validation. Download from https://www.apple.com/certificateauthority/
# (Apple Root CA - G2 and G3). Verification fails closed without them.
ASL_APPLE_ROOT_CA_DIR=./apple-roots
ASL_APPLE_BUNDLE_ID=com.onesilo.asl
